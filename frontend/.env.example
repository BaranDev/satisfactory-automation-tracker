# Frontend Environment Variables

# Poll interval for checking remote updates (milliseconds)
# Lower = more responsive but more API calls
# Default: 5000 (5 seconds)
VITE_POLL_INTERVAL_MS=5000

# Base URL for item asset images
# Set this to your S3/MinIO public assets URL
# If not set, falls back to /api/assets (proxied through backend)
# VITE_ASSETS_BASE_URL=http://localhost:9000/satisfactory-assets
